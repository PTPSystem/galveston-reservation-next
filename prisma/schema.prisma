// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Galveston Reservation System - Modern Stack
// Next.js + Prisma + Neon + Vercel
// ============================================

model BookingRequest {
  id                Int             @id @default(autoincrement())
  guestName         String          @map("guest_name")
  guestEmail        String          @map("guest_email")
  guestPhone        String?         @map("guest_phone")
  startDate         DateTime        @map("start_date")
  endDate           DateTime        @map("end_date")
  numGuests         Int             @default(1) @map("num_guests")
  specialRequests   String?         @map("special_requests")
  status            BookingStatus   @default(PENDING)
  approvalToken     String?         @unique @map("approval_token")
  rejectionReason   String?         @map("rejection_reason")

  // Source of the booking/request
  source            BookingSource   @default(DIRECT)

  // External system ID (e.g. VRBO iCal UID) for deduplication on sync
  externalId        String?         @unique @map("external_id")

  // Pricing (stored as JSON for flexibility)
  pricing           Json?           // See BookingPricing type in code

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  approvedAt        DateTime?       @map("approved_at")
  rejectedAt        DateTime?       @map("rejected_at")

  // Google Calendar integration (legacy)
  googleEventId     String?         @map("google_event_id")

  // Relations
  calendarEvent     CalendarEvent?
  adjustments       PricingAdjustment[]
  vrboPayout        VrboPayout?

  @@map("booking_requests")
}

model PricingAdjustment {
  id                Int      @id @default(autoincrement())
  bookingRequestId  Int      @map("booking_request_id")

  adjustmentType    String   // "daily" | "stay"
  amount            Float
  reason            String
  appliedBy         String   // admin name or id

  createdAt         DateTime @default(now())

  bookingRequest    BookingRequest @relation(fields: [bookingRequestId], references: [id])

  @@map("pricing_adjustments")
}

model HolidayPeriod {
  id          Int      @id @default(autoincrement())
  name        String
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  rate        Int      @default(700) // Holiday rate override
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([startDate, endDate])
  @@map("holiday_periods")
}

model BlockedPeriod {
  id          Int      @id @default(autoincrement())
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blocked_periods")
}

model VrboPayout {
  id                        Int      @id @default(autoincrement())
  reservationId             String   @unique @map("reservation_id")
  propertyId                String?  @map("property_id")
  unitId                    String?  @map("unit_id")
  address                   String?
  travelerFirstName         String?  @map("traveler_first_name")
  travelerLastName          String?  @map("traveler_last_name")
  bookingStatus             String?  @map("booking_status")
  checkIn                   DateTime @map("check_in")
  checkOut                  DateTime @map("check_out")
  nights                    Int
  payoutDate                DateTime? @map("payout_date")
  grossBookingAmount        Float    @map("gross_booking_amount")
  deductions                Float
  payout                    Float
  lodgingTaxOwnerRemits     Float    @map("lodging_tax_owner_remits")
  taxWithheld               Float    @map("tax_withheld")
  payoutCurrency            String?  @map("payout_currency")
  raw                       Json?
  bookingRequestId          Int?     @unique @map("booking_request_id")
  importedAt                DateTime @default(now()) @map("imported_at")

  bookingRequest            BookingRequest? @relation(fields: [bookingRequestId], references: [id])

  @@map("vrbo_payouts")
}

enum BookingSource {
  DIRECT
  VRBO
}

model CalendarEvent {
  id                Int      @id @default(autoincrement())
  googleEventId     String   @unique @map("google_event_id")
  summary           String?
  description       String?
  startDatetime     DateTime @map("start_datetime")
  endDatetime       DateTime @map("end_datetime")
  status            String?  // confirmed, tentative, cancelled
  source            String   @default("google") // google | external | manual

  bookingRequestId  Int?     @unique @map("booking_request_id")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  lastSynced        DateTime @default(now()) @map("last_synced")

  bookingRequest    BookingRequest? @relation(fields: [bookingRequestId], references: [id])

  @@map("calendar_events")
}

model SyncLog {
  id                  Int      @id @default(autoincrement())
  syncType            String   @map("sync_type") // calendar_sync | external_check
  status              String   // success | error | warning
  eventsProcessed     Int      @default(0) @map("events_processed")
  eventsAdded         Int      @default(0) @map("events_added")
  eventsUpdated       Int      @default(0) @map("events_updated")
  eventsRemoved       Int      @default(0) @map("events_removed")
  discrepanciesFound  Int      @default(0) @map("discrepancies_found")
  message             String?
  errorDetails        String?  @map("error_details")
  startedAt           DateTime @map("started_at")
  completedAt         DateTime @default(now()) @map("completed_at")

  @@map("sync_logs")
}

model EmailSetting {
  id                    Int      @id @default(autoincrement())
  propertyManagerEmail  String   @map("property_manager_email")
  ownerEmail            String   @map("owner_email")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}

model RateSetting {
  id              Int      @id @default(autoincrement())
  weekdayRate     Int      @default(500)
  weekendRate     Int      @default(650)
  holidayRate     Int      @default(700)
  weeklyDiscount  Int      @default(350)
  cleaningFee     Int      @default(300)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("rate_settings")
}

enum BookingStatus {
  PENDING
  REVIEWING
  REJECTED
  CONFIRMED
  CANCELLED
}

enum Role {
  ADMIN
  OWNER
  PROPERTY_MANAGER
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  password              String?   // hashed password for credentials login
  role                  Role      @default(PROPERTY_MANAGER)
  emailVerified         DateTime?
  lastEmailVerification DateTime? // for 30-day reconfirmation
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  invitesSent           Invite[]  @relation("Inviter")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  role      Role
  token     String   @unique
  invitedBy String
  inviter   User     @relation("Inviter", fields: [invitedBy], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}
