# ============================================
# Galveston Reservation System - Next.js (Modern)
# Environment Configuration
# ============================================

# --- Database (Neon Postgres - Free Tier) ---
# Prisma 7+ requires connection URLs to be configured in prisma.config.ts (not in schema.prisma).
#
# Recommended setup with Neon + connection pooling:
# - DATABASE_URL → Pooled connection (used by PrismaClient at runtime in Vercel)
# - DIRECT_URL   → Direct (non-pooled) connection (used by Prisma Migrate / CLI)
#
# The Vercel + Neon integration usually injects DATABASE_URL automatically in production.

# Pooled connection (for app runtime)
DATABASE_URL="postgresql://neondb_owner:npg_Fgz0QYMDp8fU@ep-snowy-river-ajv8xv8g-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct (non-pooled) connection - used for `prisma migrate dev` and other CLI commands
DIRECT_URL="postgresql://neondb_owner:npg_Fgz0QYMDp8fU@ep-snowy-river-ajv8xv8g.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- Application URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="str.ptpsystem.com"

# --- Auth.js / NextAuth ---
# Required for production. Generate with: openssl rand -base64 32
AUTH_SECRET="your-long-random-secret-here"
# For compatibility
NEXTAUTH_SECRET="your-long-random-secret-here"

# --- Resend (Transactional Email - Free Tier) ---
# Sign up at https://resend.com (recommended over Gmail SMTP for Vercel)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="bookings@yourdomain.com"

# --- Google Calendar Integration ---
GOOGLE_CALENDAR_ID="livingbayfront@gmail.com"

# Option 1: Paste the full service account JSON (good for local dev)
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"..."}'

# Option 2: For Vercel, base64 encode the JSON and use this instead
# GOOGLE_CREDENTIALS_BASE64="eyJ0eXBlIjoic2VydmljZS..."

# --- Security & Tokens ---
# Generate with: openssl rand -base64 48
APPROVAL_TOKEN_SECRET="change-this-to-a-long-random-string-min-32-chars"
TOKEN_EXPIRATION_HOURS=48

# --- Booking Business Rules ---
MIN_STAY_NIGHTS=2
MAX_STAY_NIGHTS=30
MAX_GUESTS=10

# --- Admin Notification Email (receives new booking requests) ---
BOOKING_APPROVAL_EMAIL=livingbayfront@gmail.com

# --- Vercel Cron Protection ---
# Used to secure scheduled jobs (e.g. automatic VRBO calendar sync)
# Generate a strong random string, e.g. using: openssl rand -base64 48
CRON_SECRET="your-very-long-random-string-here"

# --- VRBO iCal Integration (for bidirectional sync) ---
# Your private VRBO iCal feed URL (import blocked dates from VRBO into this system).
# Get it from VRBO Host Calendar > Export iCal (include tentative usually).
# Example: https://www.vrbo.com/icalendar/2c14cbae93c04d6c953e62e8b86903bc.ics?nonTentative&includeTentative=true
VRBO_ICAL_URL="https://www.vrbo.com/icalendar/YOUR_UNIQUE_ID_HERE.ics?nonTentative&includeTentative=true"

# Note: The automatic cron (vercel.json) runs the import daily (at midnight UTC) when CRON_SECRET and VRBO_ICAL_URL are set. (Vercel Hobby plan limits to 1 cron job per day.)
# Manual "Sync VRBO Calendar" button in /admin/requests also uses this URL.
